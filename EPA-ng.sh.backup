#!/bin/bash
#PBS -N pmoA_read_placement
#PBS -l walltime=24:00:00
#PBS -l select=1:ncpus=8:mem=32gb
#PBS -o /rds/general/user/jc224/home/pmoA_output/logs/
#PBS -e /rds/general/user/jc224/home/pmoA_output/logs/

# --- Load Modules ---
module load ANTLR/2.7.7-GCCcore-12.3.0-Java-11

# --- Activate Conda Environment ---
source ~/miniconda3/etc/profile.d/conda.sh
conda activate fungene_py2

# --- Define Paths ---
# Pass SAMPLE at submission: qsub -v SAMPLE=53394 EPA-ng.sh
if [ -z "${SAMPLE}" ]; then
    echo "ERROR: SAMPLE variable not set."
    echo "Usage: qsub -v SAMPLE=<sample_id> EPA-ng.sh"
    exit 1
fi

RDPTOOLS=/rds/general/user/jc224/home/RDPTools
SHARED_OUTDIR=/rds/general/user/jc224/home/pmoA_output/EPA_output
export OUTDIR=${SHARED_OUTDIR}/${SAMPLE}
FASTREE_DIR=/rds/general/user/jc224/home/pmoA_output/fastree_output
INPUT=/rds/general/user/jc224/home/pmoA_output/pmoa_reads/${SAMPLE}_pmoA.fasta

REF_ALPHA_MSA=${FASTREE_DIR}/USCalpha_ref_aligned.fasta
REF_GAMMA_MSA=${FASTREE_DIR}/USCgamma_ref_aligned.fasta
REF_ALPHA_TREE=${FASTREE_DIR}/USCalpha_tree.nwk
REF_GAMMA_TREE=${FASTREE_DIR}/USCgamma_tree.nwk
REF_ALPHA_SEQS=${FASTREE_DIR}/USCalpha_ref_only.fasta
REF_GAMMA_SEQS=${FASTREE_DIR}/USCgamma_ref_only.fasta

REFERENCE=${SHARED_OUTDIR}/USC_ref_combined.fasta

mkdir -p ${SHARED_OUTDIR} ${OUTDIR} ${OUTDIR}/epa_alpha_output ${OUTDIR}/epa_gamma_output \
         /rds/general/user/jc224/home/pmoA_output/logs

# --- Sanity check: Pipeline 1 outputs must exist and be non-empty ---
for f in ${REF_ALPHA_MSA} ${REF_GAMMA_MSA} ${REF_ALPHA_TREE} ${REF_GAMMA_TREE} ${REF_ALPHA_SEQS} ${REF_GAMMA_SEQS}; do
    if [ ! -f "$f" ]; then
        echo "ERROR: Required Pipeline 1 output not found: $f"
        echo "Please run fastree.sh first."
        exit 1
    fi
    if [ ! -s "$f" ]; then
        echo "ERROR: Required Pipeline 1 output is empty: $f"
        exit 1
    fi
done

# --- Sanity check: input sample FASTA must exist and be non-empty ---
if [ ! -s "${INPUT}" ]; then
    echo "ERROR: Input file not found or empty: ${INPUT}"
    exit 1
fi

# Build combined USC reference for FrameBot (shared; only built once)
if [ ! -s "${REFERENCE}" ]; then
    cat ${REF_ALPHA_SEQS} ${REF_GAMMA_SEQS} > ${REFERENCE}
    echo "Combined USC reference built: $(grep -c '>' ${REFERENCE}) sequences"
else
    echo "Combined USC reference already exists: $(grep -c '>' ${REFERENCE}) sequences (skipping rebuild)"
fi

echo "============================================"
echo "Pipeline 2: Metagenomic Read Placement"
echo "Sample:  ${SAMPLE}"
echo "Started: $(date)"
echo "============================================"
echo "Input reads: $(grep -c '>' ${INPUT})"
echo "Reference tree (alpha): ${REF_ALPHA_TREE}"
echo "Reference tree (gamma): ${REF_GAMMA_TREE}"

# ============================================================
# STEP 1: FrameBot Correction
# ============================================================
echo ""
echo "STEP 1: Running FrameBot..."

cd ${RDPTOOLS}

java -Xmx4g -jar FrameBot.jar framebot \
    -N \
    -a glocal \
    -i 0.2 \
    -l 50 \
    -o ${OUTDIR}/framebot_USC_result_${SAMPLE} \
    ${REFERENCE} \
    ${INPUT}

echo "FrameBot complete"
echo "  Corrected proteins: $(grep -c '>' ${OUTDIR}/framebot_USC_result_${SAMPLE}_corr_prot.fasta 2>/dev/null || echo 0)"
echo "  Failed sequences:   $(grep -c '>' ${OUTDIR}/framebot_USC_result_${SAMPLE}_failed_nucl.fasta 2>/dev/null || echo 0)"

# ============================================================
# STEP 2: Remove Stop Codons
# Use Python 2-compatible syntax (no f-strings, no os.replace)
# ============================================================
echo ""
echo "STEP 2: Removing sequences with internal stop codons..."

python << 'PYEOF'
from Bio import SeqIO
import os

outdir      = os.environ["OUTDIR"]
sample      = os.environ["SAMPLE"]
input_file  = outdir + "/framebot_USC_result_%s_corr_prot.fasta" % sample
output_file = outdir + "/framebot_USC_clean_%s_prot.fasta" % sample

kept = 0
removed = 0
with open(output_file, "w") as out:
    for record in SeqIO.parse(input_file, "fasta"):
        if "*" not in str(record.seq):
            out.write(">%s\n%s\n" % (record.id, str(record.seq)))
            kept += 1
        else:
            removed += 1

print("  Kept:    %d sequences" % kept)
print("  Removed: %d sequences (contained stop codons)" % removed)
PYEOF

echo "Clean sequences: $(grep -c '>' ${OUTDIR}/framebot_USC_clean_${SAMPLE}_prot.fasta)"

# ============================================================
# STEP 3: Separate USCalpha and USCgamma Reads
# ============================================================
echo ""
echo "STEP 3: Separating USCalpha and USCgamma reads by FrameBot best-match..."

grep "STATS" ${OUTDIR}/framebot_USC_result_${SAMPLE}_framebot.txt | \
    grep -E "KE386496|CP024846|FOSN01000007|JAFMSB|PLUZ01000456" | \
    awk '{print $3}' > ${OUTDIR}/USCalpha_${SAMPLE}_ids.txt

grep "STATS" ${OUTDIR}/framebot_USC_result_${SAMPLE}_framebot.txt | \
    grep "MUGK01000060" | \
    awk '{print $3}' > ${OUTDIR}/USCgamma_${SAMPLE}_ids.txt

echo "  USCalpha read IDs found: $(wc -l < ${OUTDIR}/USCalpha_${SAMPLE}_ids.txt)"
echo "  USCgamma read IDs found: $(wc -l < ${OUTDIR}/USCgamma_${SAMPLE}_ids.txt)"

# ============================================================
# STEP 4: Extract Clean USC Sequences
# ============================================================
echo ""
echo "STEP 4: Extracting clean USC sequences..."

awk 'NR==FNR{ids[$1]=1; next}
     /^>/{header=$1; sub(/^>/,"",header); found=(header in ids)}
     found{print}' \
    ${OUTDIR}/USCalpha_${SAMPLE}_ids.txt \
    ${OUTDIR}/framebot_USC_clean_${SAMPLE}_prot.fasta \
    > ${OUTDIR}/USCalpha_${SAMPLE}_clean.fasta

awk 'NR==FNR{ids[$1]=1; next}
     /^>/{header=$1; sub(/^>/,"",header); found=(header in ids)}
     found{print}' \
    ${OUTDIR}/USCgamma_${SAMPLE}_ids.txt \
    ${OUTDIR}/framebot_USC_clean_${SAMPLE}_prot.fasta \
    > ${OUTDIR}/USCgamma_${SAMPLE}_clean.fasta

echo "  USCalpha clean sequences: $(grep -c '>' ${OUTDIR}/USCalpha_${SAMPLE}_clean.fasta)"
echo "  USCgamma clean sequences: $(grep -c '>' ${OUTDIR}/USCgamma_${SAMPLE}_clean.fasta)"

# ============================================================
# STEP 5: Align queries to reference MSA with MAFFT --add
# ============================================================
echo ""
echo "STEP 5: Aligning query sequences to reference MSA..."

mafft --add ${OUTDIR}/USCalpha_${SAMPLE}_clean.fasta --keeplength ${REF_ALPHA_MSA} \
    > ${OUTDIR}/USCalpha_${SAMPLE}_combined.fasta
echo "  USCalpha combined: $(grep -c '>' ${OUTDIR}/USCalpha_${SAMPLE}_combined.fasta) sequences"

mafft --add ${OUTDIR}/USCgamma_${SAMPLE}_clean.fasta --keeplength ${REF_GAMMA_MSA} \
    > ${OUTDIR}/USCgamma_${SAMPLE}_combined.fasta
echo "  USCgamma combined: $(grep -c '>' ${OUTDIR}/USCgamma_${SAMPLE}_combined.fasta) sequences"

# ============================================================
# STEP 6: EPA-ng --split to separate ref and query sequences
# ============================================================
echo ""
echo "STEP 6: Splitting combined MSA for EPA-ng..."

epa-ng --split ${REF_ALPHA_MSA} ${OUTDIR}/USCalpha_${SAMPLE}_combined.fasta \
    --redo --outdir ${OUTDIR}/epa_alpha_output

epa-ng --split ${REF_GAMMA_MSA} ${OUTDIR}/USCgamma_${SAMPLE}_combined.fasta \
    --redo --outdir ${OUTDIR}/epa_gamma_output

# ============================================================
# STEP 6b: Fix sequence ID mismatch between reference MSA and tree
# epa-ng --split may strip the "PmoA-" prefix; add it back to match tree
# NOTE: uses Python 2-compatible syntax (shutil.move instead of os.replace)
# ============================================================
echo ""
echo "STEP 6b: Fixing reference sequence IDs to match tree labels..."

python << 'PYEOF'
import os
import shutil

outdir = os.environ["OUTDIR"]

for clade in ["alpha", "gamma"]:
    ref_fa = outdir + "/epa_%s_output/reference.fasta" % clade
    out_fa = outdir + "/epa_%s_output/reference_fixed.fasta" % clade

    if not os.path.exists(ref_fa):
        print("  WARNING: %s not found, skipping." % ref_fa)
        continue

    fixed = 0
    with open(ref_fa, "r") as fin, open(out_fa, "w") as fout:
        for line in fin:
            if line.startswith(">"):
                seq_id = line[1:].strip()
                if not seq_id.startswith("PmoA-"):
                    fout.write(">PmoA-%s\n" % seq_id)
                    fixed += 1
                else:
                    fout.write(line)
            else:
                fout.write(line)

    shutil.move(out_fa, ref_fa)   # Python 2-compatible rename
    print("  USC%s: %d IDs renamed to match tree" % (clade, fixed))
PYEOF

# Verify the fix worked
echo "  USCalpha reference IDs after fix (first 3):"
grep ">" ${OUTDIR}/epa_alpha_output/reference.fasta | head -3
echo "  USCgamma reference IDs after fix (first 3):"
grep ">" ${OUTDIR}/epa_gamma_output/reference.fasta | head -3

# ============================================================
# STEP 7: Phylogenetic Placement with EPA-ng
# Both clades use their own ref-msa (split output) and own tree
# ============================================================
echo ""
echo "STEP 7: Running EPA-ng phylogenetic placement..."

epa-ng --tree ${REF_ALPHA_TREE} \
    --ref-msa ${REF_ALPHA_MSA} \
    --query   ${OUTDIR}/epa_alpha_output/query.fasta \
    --outdir  ${OUTDIR}/epa_alpha_output \
    --redo --threads 8 --model LG+G

echo "  USCalpha placement complete: $(ls ${OUTDIR}/epa_alpha_output/*.jplace 2>/dev/null)"

epa-ng --tree ${REF_GAMMA_TREE} \
    --ref-msa ${REF_GAMMA_MSA} \
    --query   ${OUTDIR}/epa_gamma_output/query.fasta \
    --outdir  ${OUTDIR}/epa_gamma_output \
    --redo --threads 8 --model LG+G

echo "  USCgamma placement complete: $(ls ${OUTDIR}/epa_gamma_output/*.jplace 2>/dev/null)"

# ============================================================
# SUMMARY
# ============================================================
echo ""
echo "============================================"
echo "Pipeline 2 Complete: $(date)"
echo "============================================"
echo "Results Summary (Sample: ${SAMPLE}):"
echo ""
echo "  Input reads:        $(grep -c '>' ${INPUT})"
echo "  FrameBot corrected: $(grep -c '>' ${OUTDIR}/framebot_USC_result_${SAMPLE}_corr_prot.fasta)"
echo "  Clean proteins:     $(grep -c '>' ${OUTDIR}/framebot_USC_clean_${SAMPLE}_prot.fasta)"
echo "  USCalpha sequences: $(grep -c '>' ${OUTDIR}/USCalpha_${SAMPLE}_clean.fasta)"
echo "  USCgamma sequences: $(grep -c '>' ${OUTDIR}/USCgamma_${SAMPLE}_clean.fasta)"
echo ""
echo "  Placement outputs:"
echo "    ${OUTDIR}/epa_alpha_output/"
echo "    ${OUTDIR}/epa_gamma_output/"
echo ""
echo "Next steps:"
echo "  - Visualise .jplace files in iTOL or gappa"
echo "  - Filter placements by LWR score (recommend > 0.5)"
echo "============================================"
